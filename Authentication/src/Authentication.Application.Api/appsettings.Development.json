{
  "DatabaseOptions": {
    "AuthConnectionString": "Host=postgres;Database=auth;Username=postgres;Password=Password123!!"
  },
  "JwtOptions": {
    "SigningKey": "your-super-secret-key-that-is-at-least-32-characters-long-for-production",
    "Issuer": "http://authentication.api:5000/",
    "Audience": "auth-api",
    "AccessTokenLifetime": "01:00:00",
    "RefreshTokenLifetime": "7.00:00:00"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/health%' or RequestPath like '/swagger%' or RequestPath = '/'"
        }
      }
    ],
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.AspNetCore": "Error",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "Microsoft.AspNetCore.Authorization": "Debug",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "Using": [
      "Serilog.Expressions",
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Sinks.OpenTelemetry"
    ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://seq:5341" }
      },
      {
        "Name": "Otel",
        "Args": { "serverUrl": "http://aspire-dashboard:18889" }
      }
    ]
  }
}
